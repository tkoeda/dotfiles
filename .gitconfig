# This is Git's per-user configuration file.
# User-specific settings (name, email, credentials) are in .gitconfig.local

[alias]
	gl = config --global -l
	can = commit --amend --no-edit
	a = add
	b = branch
	l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	please = push --force-with-lease
	paid = push
	c = commit -m
	ch = checkout
	rv = remote -v
	s = status
	unstage = restore --staged
	chb = checkout -b
	cleanup-merged = "!f(){ \\\n  base=${1:-$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD | sed \"s#^origin/##\")}; \\\n  git for-each-ref --merged \"$base\" --format=\"%(refname:short)\" refs/heads | \\\n  grep -v -x \"$base\" | \\\n  while IFS= read -r b; do \\\n    [ -n \"$b\" ] && git branch -d -- \"$b\"; \\\n  done; \\\n}; f"
	cleanup-gone = "!f(){ git fetch -p && git for-each-ref --format=\"%(refname:short) %(upstream:track)\" refs/heads | awk '$2==\"[gone]\"{print $1}' | while IFS= read -r b; do git branch -D -- \"$b\"; done; }; f"
	cleanup-local-only = "!f(){ current=$(git symbolic-ref --quiet --short HEAD); git for-each-ref --format='%(refname:short) %(upstream:short)' refs/heads | awk '$2==\"\"{print $1}' | grep -v -x \"$current\" | while IFS= read -r b; do [ -n \"$b\" ] && git branch -d -- \"$b\"; done; }; f"
	pl = !git pull origin $(git branch --show-current)

[pager]
	branch = false

[pull]
	rebase = false
	ff = true

[diff]
	tool = vimdiff

[init]
	defaultBranch = main

[push]
	autoSetupRemote = false

[include]
	path = ~/dotfiles/.gitconfig.local
	
[url "git@github.com:"]
	insteadOf = https://github.com/

